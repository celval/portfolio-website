---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Célia Valette — Freelance Senior Product and Visual Designer" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`.replace('//', '/')} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}favicon.svg`.replace('//', '/')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands." />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
