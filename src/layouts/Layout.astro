---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Célia Valette — Freelance Senior Product and Visual Designer" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://celiavalette.com/" />
    <meta property="og:image" content="https://celiavalette.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands." />
    <meta name="twitter:image" content="https://celiavalette.com/og-image.jpg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
