---
import { getImage } from 'astro:assets';
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/*.jpg',
  { eager: true }
);
const featured = allImages['/src/assets/images/projects/villa-soulia-1.jpg'];
const optimized = featured ? await getImage({ src: featured.default, height: 800, format: 'webp', quality: 90 }) : null;
---

<section class="px-4 md:px-8 pt-12 md:pt-20 pb-12 md:pb-20">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center">
    <div class="md:col-span-6">
      <p class="font-geist text-sm uppercase tracking-[0.15em] text-text-light mb-6">Available for projects · 2026</p>
      <h1 class="font-editorial text-[36px] md:text-[56px] leading-[1.05] tracking-[-0.01em] mb-6">
        Bonjour I'm Célia — Freelance Senior Product and Visual Designer.
      </h1>
      <p class="font-geist text-[16px] md:text-[18px] leading-[1.5] text-text-light max-w-[480px]">
        Working with startups, design studios and e-commerce brands across product, brand and UI.
      </p>
    </div>
    <div class="md:col-span-6">
      {optimized && (
        <div class="rounded-2xl overflow-hidden bg-gray-100 aspect-[4/5]">
          <img src={optimized.src} alt="Featured project" class="w-full h-full object-cover" />
        </div>
      )}
    </div>
  </div>
</section>
