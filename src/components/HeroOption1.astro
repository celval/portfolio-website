---
const clients = ["Ennismore", "Wimbledon", "Bttr", "Delli", "Different Kind", "Allergan", "Villa Soulia"];
---

<section class="px-4 md:px-8 pt-12 md:pt-16 pb-0 overflow-hidden">
  <div class="max-w-[900px]">
    <h1 class="font-editorial text-[48px] md:text-[96px] leading-[0.95] tracking-[-0.02em] mb-6">
      Bonjour,<br/>I'm Célia.
    </h1>
    <p class="font-editorial text-[20px] md:text-[26px] leading-[1.3] max-w-[560px] text-text">
      Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands.
    </p>
  </div>

  <!-- Marquee -->
  <div class="mt-16 md:mt-24 -mx-4 md:-mx-8 border-y border-black/10 py-6 overflow-hidden">
    <div class="flex gap-12 whitespace-nowrap animate-[marquee_30s_linear_infinite]">
      {[...clients, ...clients, ...clients].map((c) => (
        <span class="font-editorial text-[28px] md:text-[36px] text-text/80">{c} <span class="text-text/30 mx-4">●</span></span>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
