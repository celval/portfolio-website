---
import { getImage } from 'astro:assets';
import img1 from '../assets/images/projects/ennismore-1.jpg';
import img2 from '../assets/images/projects/delli-1.jpg';
import img3 from '../assets/images/projects/different-kind-1.jpg';

const opt1 = await getImage({ src: img1, width: 400, format: 'webp', quality: 80 });
const opt2 = await getImage({ src: img2, width: 350, format: 'webp', quality: 80 });
const opt3 = await getImage({ src: img3, width: 300, format: 'webp', quality: 80 });
---

<!-- Option 1: Stacked Cards with Rotation -->
<section class="px-4 md:px-8 pt-16 md:pt-24 pb-20 md:pb-32 relative overflow-hidden bg-[#DCE3F9] md:min-h-[420px]">
  <div class="max-w-[586px]">
    <h1 class="font-editorial text-[28px] md:text-[38px] leading-[1.2] text-text">
      Bonjour I'm Célia — Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands.
    </h1>
  </div>

  <div class="hidden md:block absolute right-[80px] top-[50%] -translate-y-1/2 w-[420px] h-[320px]" aria-hidden="true">
    <img src={opt3.src} alt="" class="absolute w-[280px] h-[200px] object-cover rounded-xl shadow-lg" style="top: 20px; left: 0; transform: rotate(-6deg);" />
    <img src={opt2.src} alt="" class="absolute w-[280px] h-[200px] object-cover rounded-xl shadow-lg" style="top: 40px; left: 60px; transform: rotate(3deg);" />
    <img src={opt1.src} alt="" class="absolute w-[300px] h-[210px] object-cover rounded-xl shadow-xl" style="top: 50px; left: 100px; transform: rotate(-1deg);" />
  </div>
</section>
