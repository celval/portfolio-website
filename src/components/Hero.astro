---
import { Image } from 'astro:assets';
import img1 from '../assets/images/projects/hero-1.jpg';
import img2 from '../assets/images/projects/hero-2.jpg';
import img3 from '../assets/images/projects/hero-3.jpg';
import img4 from '../assets/images/projects/hero-4.jpg';
import img5 from '../assets/images/projects/hero-5.jpg';
import img6 from '../assets/images/projects/hero-6.jpg';
import img7 from '../assets/images/projects/hero-7.jpg';

const tiles = [img1, img2, img3, img4, img5, img6, img7];
---

<section class="pt-10 md:pt-14 pb-12 md:pb-16 overflow-hidden text-text" style="background-color: #D5E3F2;">
  <div class="px-4 md:px-8 mb-10 md:mb-14 hero-fade">
    <h1 class="font-editorial text-[34px] md:text-[48px] leading-[1.1] text-text tracking-[-0.5px] max-w-[1100px]">
      Bonjour I'm Célia — Freelance Senior Product and Visual Designer working with startups, design studios and e&#8209;commerce brands.
    </h1>
  </div>

  <div class="marquee hero-fade hero-fade-delay">
    <div class="marquee-track">
      {[...tiles, ...tiles].map((src) => (
        <div class="marquee-item">
          <Image
            src={src}
            alt=""
            widths={[600, 900]}
            sizes="(max-width: 768px) 320px, 480px"
            format="webp"
            quality={85}
            class="rounded-md"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .marquee {
    width: 100%;
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    width: max-content;
    animation: marqueeScroll 50s linear infinite;
  }
  .marquee-item {
    width: 320px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 12px 32px -12px rgba(0, 0, 0, 0.15);
  }
  .marquee-item img {
    width: 100%;
    height: auto;
    display: block;
  }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 4px)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  .hero-fade { opacity: 0; animation: heroFade 1.2s ease-out 0.1s forwards; }
  .hero-fade-delay { animation-delay: 0.4s; }
  @keyframes heroFade { to { opacity: 1; } }
</style>
