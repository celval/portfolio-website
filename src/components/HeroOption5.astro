<section class="px-4 md:px-8 pt-20 md:pt-32 pb-20 md:pb-32">
  <div class="max-w-[1000px]">
    <h1 class="font-editorial text-[36px] md:text-[68px] leading-[1.1] tracking-[-0.01em]">
      Bonjour, I'm Célia.<br/>
      A freelance designer for
      <span class="relative inline-block align-baseline">
        <span class="rotator inline-block italic">
          <span>startups.</span>
          <span>studios.</span>
          <span>e-commerce.</span>
          <span>founders.</span>
        </span>
      </span>
