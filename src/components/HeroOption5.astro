<style>
  .rotator {
    overflow: hidden;
    height: 1.1em;
    vertical-align: bottom;
    position: relative;
  }
  .rotator span {
    display: block;
    animation: rotate 8s steps(4) infinite;
  }
  @keyframes rotate {
    0%, 25% { transform: translateY(0); }
    25.01%, 50% { transform: translateY(-1.1em); }
    50.01%, 75% { transform: translateY(-2.2em); }
    75.01%, 100% { transform: translateY(-3.3em); }
  }
</style>
