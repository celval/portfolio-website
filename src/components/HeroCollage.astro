---
import { Image } from 'astro:assets';
import img1 from '../assets/images/projects/ennismore-2.jpg';
import img2 from '../assets/images/projects/different-kind-1.jpg';
import img3 from '../assets/images/projects/villa-soulia-2.jpg';
import img5 from '../assets/images/projects/allergan-3.jpg';
---

<section class="bg-[#D5E3F2] px-4 md:px-8 pt-10 md:pt-14 pb-12 md:pb-16">
  <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-center">
    <div class="hero-fade">
      <h1 class="font-editorial text-[36px] md:text-[44px] leading-[1.1] text-text tracking-[-0.5px]">
        Bonjour I'm Célia — Freelance Senior Product and Visual Designer working with startups, design studios and e&#8209;commerce brands.
      </h1>
    </div>

    <div class="relative w-full aspect-[5/4] hero-fade hero-fade-delay">
      <div class="collage-card absolute top-0 right-[6%] w-[36%] aspect-square">
        <Image src={img2} alt="" widths={[300, 500]} sizes="200px" format="webp" quality={85} class="w-full h-full object-cover" />
      </div>
      <div class="collage-card absolute top-[26%] left-0 w-[72%] aspect-[16/10]">
        <Image src={img1} alt="" widths={[500, 800, 1100]} sizes="(max-width: 768px) 60vw, 400px" format="webp" quality={85} class="w-full h-full object-cover" />
      </div>
      <div class="collage-card absolute top-[55%] left-[18%] w-[40%] aspect-square">
        <Image src={img3} alt="" widths={[300, 500]} sizes="220px" format="webp" quality={85} class="w-full h-full object-cover" />
      </div>
      <div class="collage-card absolute bottom-0 right-0 w-[58%] aspect-[16/9]">
        <Image src={img5} alt="" widths={[400, 700]} sizes="(max-width: 768px) 50vw, 320px" format="webp" quality={85} class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</section>

<style>
  .collage-card {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 40px -12px rgba(0, 0, 0, 0.18), 0 4px 12px -4px rgba(0, 0, 0, 0.08);
  }
  .hero-fade { opacity: 0; animation: heroFade 1.2s ease-out 0.1s forwards; }
  .hero-fade-delay { animation-delay: 0.4s; }
  @keyframes heroFade { to { opacity: 1; } }
</style>
