---
const text = "Bonjour I'm Célia — Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands.";
const words = text.split(" ");
---

<section class="px-4 md:px-8 pt-16 md:pt-24 pb-20 md:pb-32">
  <div class="max-w-[900px] mx-auto text-center">
    <h1 class="font-editorial text-[50px] leading-[1.15] text-text">
      {words.map((word, i) => (
        <span class="word-mask">
          <span class="word-inner" style={`animation-delay: ${i * 60}ms`}>{word}</span>
        </span>
      ))}
    </h1>
  </div>
</section>

<style>
  .word-mask {
    display: inline-block;
    overflow: hidden;
    margin-right: 0.25em;
    vertical-align: bottom;
    line-height: 1.15;
  }
  .word-inner {
    display: inline-block;
    transform: translateY(110%);
    animation: wordMask 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes wordMask {
    to { transform: translateY(0); }
  }
</style>
