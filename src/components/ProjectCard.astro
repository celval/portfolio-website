---
import { getImage } from 'astro:assets';
import ProjectCarousel from './ProjectCarousel.tsx';
import { type Project, tagColors } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

// Import all project images for optimization
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/*.jpg',
  { eager: true }
);

// Get optimized URLs for this project's images
const optimizedImages = await Promise.all(
  project.images.map(async (src) => {
    const assetPath = src.replace('/images/projects/', '/src/assets/images/projects/');
    const imageModule = allImages[assetPath];
    if (!imageModule) return src;

    const optimized = await getImage({
      src: imageModule.default,
      width: 1000,
      format: 'webp',
      quality: 85,
    });
    return optimized.src;
  })
);
---

<article class="pb-[160px] last:pb-0">
  <!-- Header row -->
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-8">
    <div>
      <h3 class="font-geist text-[22px] md:text-[26px] leading-[1.2] mb-3 md:max-w-[600px] tracking-[-0.25px]">
        {project.title} — {project.description}
      </h3>
      <div class="flex flex-wrap gap-1">
        {project.tags.map((tag) => (
          <span
            class="px-2 py-1 text-xs rounded-sm text-black"
            style={`background-color: ${tagColors[tag] || '#e0e0e0'}`}
          >
            {tag}
          </span>
        ))}
      </div>
    </div>
    <button
      type="button"
      disabled
      class="hidden md:inline-block shrink-0 px-5 py-2.5 text-base border border-black/20 text-black/40 rounded-full whitespace-nowrap cursor-not-allowed self-start"
    >
      Case study coming soon
    </button>
  </div>

  <!-- Image carousel -->
  <ProjectCarousel
    client:visible
    images={optimizedImages}
    title={project.title}
    hint="cursor"
    imageStyles={project.imageStyles}
  />

  <!-- Mobile-only button below images -->
  <button
    type="button"
    disabled
    class="md:hidden mt-6 px-3.5 py-1.5 text-sm border border-black/20 text-black/40 rounded-full whitespace-nowrap cursor-not-allowed"
  >
    Case study coming soon
  </button>
</article>
