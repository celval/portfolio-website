---
import { getImage } from 'astro:assets';
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/*.jpg',
  { eager: true }
);
const picks = [
  '/src/assets/images/projects/delli-1.jpg',
  '/src/assets/images/projects/different-kind-1.jpg',
  '/src/assets/images/projects/villa-soulia-2.jpg',
  '/src/assets/images/projects/ennismore-1.jpg',
];
const optimized = await Promise.all(picks.map(async (p) => {
  const m = allImages[p];
  if (!m) return null;
  return await getImage({ src: m.default, height: 400, format: 'webp', quality: 85 });
}));
---

<section class="px-4 md:px-8 pt-12 md:pt-20 pb-20 md:pb-32 relative overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div class="relative z-10">
      <h1 class="font-editorial text-[32px] md:text-[44px] leading-[1.15] tracking-[-0.01em] mb-6">
        Bonjour I'm Célia — Freelance Senior Product and Visual Designer working with startups, design studios and e-commerce brands.
      </h1>
      <a href="#contact" class="inline-block px-5 py-2.5 text-base border border-black rounded-full hover:bg-black hover:text-white transition-colors">
        Get in touch
      </a>
    </div>

    <div class="relative h-[420px] md:h-[480px]">
      {optimized[0] && (
        <div class="absolute top-0 left-[10%] w-[55%] aspect-[3/4] rounded-xl overflow-hidden shadow-xl rotate-[-6deg] bg-gray-100 hover:rotate-0 transition-transform duration-500">
          <img src={optimized[0].src} alt="" class="w-full h-full object-cover" />
        </div>
      )}
      {optimized[1] && (
        <div class="absolute top-[15%] right-0 w-[50%] aspect-[4/5] rounded-xl overflow-hidden shadow-xl rotate-[5deg] bg-gray-100 hover:rotate-0 transition-transform duration-500">
          <img src={optimized[1].src} alt="" class="w-full h-full object-cover" />
        </div>
      )}
      {optimized[2] && (
        <div class="absolute bottom-0 left-[25%] w-[45%] aspect-square rounded-xl overflow-hidden shadow-xl rotate-[-3deg] bg-gray-100 hover:rotate-0 transition-transform duration-500">
          <img src={optimized[2].src} alt="" class="w-full h-full object-cover" />
        </div>
      )}
      {optimized[3] && (
        <div class="absolute bottom-[10%] right-[8%] w-[35%] aspect-[3/4] rounded-xl overflow-hidden shadow-xl rotate-[8deg] bg-gray-100 hover:rotate-0 transition-transform duration-500">
          <img src={optimized[3].src} alt="" class="w-full h-full object-cover" />
        </div>
      )}
    </div>
  </div>
</section>
