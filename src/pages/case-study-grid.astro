---
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import HeaderClient from '../components/HeaderClient';
import Hero from '../components/Hero.astro';
import { projects, tagColors } from '../data/projects';

const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/*.jpg', { eager: true });

const cards = await Promise.all(projects.map(async (p) => {
  const src = p.images[0];
  const m = allImages[src.replace('/images/projects/', '/src/assets/images/projects/')];
  const optimized = m
    ? (await getImage({ src: m.default, width: 1200, format: 'webp', quality: 85 })).src
    : src;
  return { project: p, thumbnail: optimized };
}));
---

<Layout title="Case study grid">
  <HeaderClient client:load />
  <Hero />
  <main class="px-4 md:px-8 pt-16 md:pt-24 pb-32">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {cards.map(({ project, thumbnail }) => (
        <article>
          <header class="flex flex-col md:flex-row md:items-start md:justify-between gap-3 mb-4">
            <div class="min-w-0">
              <h3 class="font-geist text-[20px] md:text-[22px] leading-[1.25] mb-2 tracking-[-0.25px]">
                {project.title} — {project.description}
              </h3>
              <div class="flex flex-wrap gap-1">
                {project.tags.map((tag) => (
                  <span class="px-2 py-1 text-xs rounded-sm text-black" style={`background-color: ${tagColors[tag] || '#e0e0e0'}`}>{tag}</span>
                ))}
              </div>
            </div>
            <button type="button" disabled class="shrink-0 px-4 py-2 text-sm border border-black/20 text-black/40 rounded-full whitespace-nowrap cursor-not-allowed">
              Coming soon
            </button>
          </header>

          <div class="aspect-square rounded-lg overflow-hidden bg-gray-100">
            <img src={thumbnail} alt={`${project.title} — thumbnail`} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>
