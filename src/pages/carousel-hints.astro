---
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import HeaderClient from '../components/HeaderClient';
import ProjectCarousel from '../components/ProjectCarousel.tsx';
import { projects, tagColors } from '../data/projects';

const project = projects[0];

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/*.jpg',
  { eager: true }
);

const optimizedImages = await Promise.all(
  project.images.map(async (src) => {
    const assetPath = src.replace('/images/projects/', '/src/assets/images/projects/');
    const imageModule = allImages[assetPath];
    if (!imageModule) return src;
    const optimized = await getImage({
      src: imageModule.default,
      width: 800,
      height: 800,
      fit: 'cover',
      format: 'webp',
      quality: 85,
    });
    return optimized.src;
  })
);

const variants: Array<{ key: 'cursor' | 'caption' | 'nudge'; label: string; note: string }> = [
  { key: 'cursor', label: 'Option 1 — Custom cursor pill', note: 'A "← Drag →" pill follows the cursor while hovering the carousel.' },
  { key: 'caption', label: 'Option 2 — Static caption', note: 'A small caption sits below the carousel.' },
  { key: 'nudge', label: 'Option 3 — First-view nudge', note: 'The carousel auto-shifts a little when it enters the viewport, then snaps back.' },
];
---

<Layout title="Carousel hint options">
  <HeaderClient client:load />
  <main class="pb-32">
    {variants.map((v) => (
      <section class="pt-12">
        <div class="px-4 md:px-8 mb-6">
          <p class="font-geist text-xs uppercase tracking-[0.15em] text-text-light mb-2">{v.label}</p>
          <p class="font-geist text-sm text-text-light max-w-[600px]">{v.note}</p>
        </div>
        <div class="px-4 md:px-8">
          <h3 class="font-geist text-[22px] md:text-[26px] leading-[1.2] mb-3 md:max-w-[600px] tracking-[-0.25px]">
            {project.title} — {project.description}
          </h3>
          <div class="flex flex-wrap gap-1 mb-8">
            {project.tags.map((tag) => (
              <span class="px-2 py-1 text-xs rounded-sm text-black" style={`background-color: ${tagColors[tag] || '#e0e0e0'}`}>{tag}</span>
            ))}
          </div>
          <ProjectCarousel client:visible images={optimizedImages} title={project.title} hint={v.key} />
        </div>
      </section>
    ))}
  </main>
</Layout>
